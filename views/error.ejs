<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Error <%= code %></title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.2/css/bootstrap.min.css">

  <style>
    body {
      background: linear-gradient(135deg, #ff6b6b, #f06595);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .error-box {
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      max-width: 600px;
      width: 100%;
      animation: pop 0.3s ease;
    }
    @keyframes pop {
      from { transform: scale(.9); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    .step-badge {
      background: #f06595;
    }
  </style>
</head>
<body>

  <div class="error-box text-center">
    <h1 class="display-4 fw-bold text-danger"><%= code %></h1>
    <p class="lead text-secondary mb-4"><%= message %></p>

    <% if (typeof details !== "undefined" && details.length > 0) { %>
      <h5 class="fw-bold text-start">Detail Error:</h5>
      
      <ul class="list-group mt-3">
        <% details.forEach((err, index) => { %>
          <li class="list-group-item d-flex align-items-center">
            <span class="badge step-badge rounded-pill me-3">Step <%= index + 1 %></span>
            <%= err %>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <a href="/" class="btn btn-dark mt-4 px-4 py-2">Kembali ke Home</a>
  </div>

</body>
</html>
